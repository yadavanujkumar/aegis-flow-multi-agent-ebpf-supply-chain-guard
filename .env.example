# ─── Aegis-Flow Orchestrator – Environment Variables ─────────────────────────
# Copy this file to .env and populate all values before running.
# .env is in .gitignore and must NEVER be committed.

# ─── Server ──────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ─── NATS ────────────────────────────────────────────────────────────────────
NATS_URL=nats://localhost:4222
NATS_RECONNECT_MAX=10

# ─── Ollama (AI analysis) ─────────────────────────────────────────────────────
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3
OLLAMA_TIMEOUT_MS=30000
OLLAMA_RETRY_MAX=3

# ─── Slack (alerting) ────────────────────────────────────────────────────────
# Obtain from https://api.slack.com/apps → Incoming Webhooks
SLACK_WEBHOOK_URL=
SLACK_RETRY_MAX=3

# ─── Authentication ───────────────────────────────────────────────────────────
# 32+ character random string; leave empty to disable API-key auth (dev only)
API_KEY=

# ─── Security thresholds ─────────────────────────────────────────────────────
MALICIOUS_CONFIDENCE_THRESHOLD=0.8

# ─── Logging ─────────────────────────────────────────────────────────────────
# Options: error | warn | info | http | verbose | debug | silly
LOG_LEVEL=info

# ─── Metrics ─────────────────────────────────────────────────────────────────
METRICS_ENABLED=true

# ─── Rate Limiting ───────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
